{
  "name": "vault-engine-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest",
    "test:compact": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/openclaw-plugin/tsconfig.json && tsc --noEmit -p bin/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@vitest/coverage-v8": "4.1.2",
    "typescript": "^5.8.3",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "@ghostwater/vault-engine": "workspace:^",
    "commander": "^14.0.3"
  }
}
