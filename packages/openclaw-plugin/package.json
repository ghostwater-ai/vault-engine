{
  "name": "@ghostwater/vault-engine-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw plugin for vault-engine retrieval",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/plugin.js"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build && node build.mjs",
    "clean": "tsc --build --clean",
    "prepack": "node prepack.mjs",
    "postpack": "node postpack.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghostwater-ai/vault-engine.git",
    "directory": "packages/openclaw-plugin"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "stemmer": "^2.0.1"
  },
  "devDependencies": {
    "@ghostwater/vault-engine": "workspace:*",
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
